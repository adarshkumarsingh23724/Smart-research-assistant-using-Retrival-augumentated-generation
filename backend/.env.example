# Groq API Key (required) — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Default Groq model (optional — defaults to llama-3.3-70b-versatile)
# Available models:
#   llama-3.3-70b-versatile        (default, fast + smart)
#   llama-3.1-8b-instant           (ultra fast)
#   deepseek-r1-distill-llama-70b  (deep reasoning, no Ollama needed)
#   deepseek-r1-distill-qwen-32b   (balanced reasoning)
#   gemma2-9b-it                   (Google, concise)
#   qwen-qwq-32b                   (Alibaba reasoning)
GROQ_MODEL=llama-3.3-70b-versatile
